        "sendTo": "={{ $json.sheet.Email }} ",
        "subject": "=Selamat Datang di Perusahaan, {{ $json.sheet['First Name'] }} {{ $json.sheet['Last Name'] }}! 🚀",
        "message": "=Hi {{ $json.sheet['First Name'] }} {{ $json.sheet['Last Name'] }},<br><br>\n\nSelamat datang di Perusahaan! Kami sangat senang Anda bergabung sebagai <b>{{ $json.sheet.Position }}</b> mulai <b>{{ $json.sheet['Start Date'] }}</b>.<br><br>\n\nBerikut adalah daftar tugas onboarding Anda yang perlu diselesaikan:\n<ul>\n  <li>{{ $json.checklist.join('</li><li>') }}</li>\n</ul>\n\nJika ada pertanyaan atau kendala, silakan langsung membalas email ini.<br><br>\n\nSalam hangat,<br>\n<b>Tim HR Perusahaan</b>",
