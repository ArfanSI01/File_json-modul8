    {
      "parameters": {
        "jsCode": "// 1. Ambil semua data dari node Checklist\nconst items = $('Checklist').all();\n\n// 2. Ambil teks tugasnya saja\nconst rawTasks = items.map(i => i.json['Checklist Onboarding Karyawan']);\n\n// 3. HAPUS DUPLIKAT menggunakan \"Set\"\nconst uniqueTasks = [...new Set(rawTasks)];\n\n// 4. Ambil data karyawan (ambil yang pertama saja)\nconst sheetData = $('Sheet Onboarding Karyawan').first().json;\n\nreturn [\n  {\n    json: {\n      checklist: uniqueTasks,\n      sheet: sheetData\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
